# AirVPN WireGuard credentials — all three come from the .conf file downloaded from
# https://airvpn.org → Client Area → Config Generator → WireGuard → select servers → Download
WIREGUARD_PRIVATE_KEY=<your-airvpn-wireguard-private-key>
WIREGUARD_PRESHARED_KEY=<your-airvpn-wireguard-preshared-key>
WIREGUARD_ADDRESSES=<your-airvpn-wireguard-addresses>   # e.g. 10.129.178.159/32

# qBittorrent WebUI credentials — set in qBittorrent: Tools → Options → Web UI
QBT_USERNAME=admin
QBT_PASSWORD=<your-qbittorrent-password>
QBT_BASE_URL=http://XX.X.XX.XXX:8080   # LAN IP:port of the qBittorrent WebUI

# NAS sudo password — used by deploy.sh to run docker commands over SSH
SYSOP_SSH=<your-nas-sudo-password>
